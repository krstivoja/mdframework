{# Right-rail sidebar. Receives optional:
     recent  — array of page records
     tags    — array of tag strings #}
<aside class="sidebar">
  <section class="sidebar-block sidebar-about">
    <h3>About</h3>
    <p>{{ config.site.tagline|default('A blog about the things we make and the things we think about.') }}</p>
  </section>

  {% if recent is iterable and recent|length %}
    <section class="sidebar-block">
      <h3>Recent posts</h3>
      <ul class="sidebar-list">
        {% for p in recent|slice(0,5) %}
          <li>
            <a href="{{ p.url }}">{{ p.title }}</a>
            {% if p.date %}<time>{{ p.date|date('M j, Y') }}</time>{% endif %}
          </li>
        {% endfor %}
      </ul>
    </section>
  {% endif %}

  {% if tags is iterable and tags|length %}
    <section class="sidebar-block">
      <h3>Tags</h3>
      <ul class="tags">
        {% for t in tags %}
          <li><a class="tag" href="{{ slug_url(t, 'tags') }}">{{ t }}</a></li>
        {% endfor %}
      </ul>
    </section>
  {% endif %}

  <section class="sidebar-block sidebar-newsletter">
    <h3>Newsletter</h3>
    <p>One short post a week. No spam.</p>
    <form action="#" method="post" class="newsletter-form">
      <input type="email" name="email" placeholder="you@domain.com" required>
      <button type="submit" class="btn-cta">Subscribe</button>
    </form>
  </section>
</aside>
