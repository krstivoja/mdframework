{{ partial('header', { page_title: term ~ ' — ' ~ taxonomy|capitalize }) }}

<section class="archive">
  <header class="archive-header">
    <p class="eyebrow">{{ taxonomy|upper }}</p>
    <h1 class="display archive-title">{{ term }}</h1>
  </header>

  {% if posts is iterable and posts|length %}
    <div class="cards-grid">
      {% for post in posts %}
        {{ partial('card', { post: post }) }}
      {% endfor %}
    </div>
  {% else %}
    <p class="empty">Nothing tagged <strong>{{ term }}</strong>.</p>
  {% endif %}

  {{ partial('pagination', {
    page: page|default(1),
    total_pages: total_pages|default(1),
    base_url: '/' ~ taxonomy ~ '/' ~ term_slug
  }) }}
</section>

{{ partial('footer') }}
