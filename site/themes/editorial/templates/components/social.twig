{# Social icons row — small filled circles. Edit URLs in config.site.social. #}
{% set links = config.site.social|default({
  facebook:  '#',
  instagram: '#',
  twitter:   '#',
  pinterest: '#',
}) %}
<ul class="social">
  {% if links.facebook %}<li><a href="{{ links.facebook }}" aria-label="Facebook">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M14 9.5h2.5l.5-3H14V4.5c0-.8.3-1.5 1.5-1.5H17V.2c-.4 0-1.5-.2-2.7-.2C11.7 0 10 1.7 10 4.2v2.3H7v3h3V20h4z"/></svg>
  </a></li>{% endif %}
  {% if links.instagram %}<li><a href="{{ links.instagram }}" aria-label="Instagram">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2 0 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.4 1 .4 2.2.1 1.3.1 1.6.1 4.8s0 3.6-.1 4.8c0 1.2-.2 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .4-2.2.4-1.3.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2 0-1.8-.2-2.2-.4-.6-.2-1-.5-1.4-.9a3.7 3.7 0 0 1-.9-1.4c-.2-.4-.4-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.8c0-1.2.2-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.4 2.2-.4C8.4 2.2 8.8 2.2 12 2.2zm0 5.3a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9zm5.4-.3a1.1 1.1 0 1 1-2.2 0 1.1 1.1 0 0 1 2.2 0zM12 9.6a2.4 2.4 0 1 1 0 4.8 2.4 2.4 0 0 1 0-4.8z"/></svg>
  </a></li>{% endif %}
  {% if links.twitter %}<li><a href="{{ links.twitter }}" aria-label="X">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.2 2H21l-6.6 7.5L22 22h-6.1l-4.8-6.3L5.6 22H3l7-8L2 2h6.2l4.4 5.8L18.2 2zm-1 18h1.6L7 4H5.3l11.9 16z"/></svg>
  </a></li>{% endif %}
  {% if links.pinterest %}<li><a href="{{ links.pinterest }}" aria-label="Pinterest">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0a12 12 0 0 0-4.4 23.2c-.1-1-.2-2.4 0-3.5l1.5-6.4s-.4-.8-.4-1.9c0-1.8 1-3.2 2.4-3.2 1.1 0 1.6.8 1.6 1.8 0 1.1-.7 2.7-1 4.2-.3 1.3.6 2.4 1.9 2.4 2.3 0 4-2.4 4-5.8 0-3-2.2-5.2-5.3-5.2a5.5 5.5 0 0 0-5.7 5.5c0 1.1.4 2.3 1 2.9.1.1.1.2.1.3l-.3 1.4c0 .2-.2.3-.4.2-1.5-.7-2.4-2.9-2.4-4.7 0-3.8 2.7-7.3 8-7.3 4.2 0 7.4 3 7.4 7 0 4.2-2.6 7.5-6.3 7.5-1.2 0-2.4-.6-2.8-1.4l-.7 2.9c-.3 1-1 2.3-1.4 3A12 12 0 1 0 12 0z"/></svg>
