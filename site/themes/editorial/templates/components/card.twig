{# Square-thumb post card. Receives:
     post — page record #}
<article class="card">
  <a class="card-thumb" href="{{ post.url }}">
    {% if post.image or post.cover %}
      <img src="{{ post.image|default(post.cover) }}" alt="{{ post.title }}">
    {% else %}
      <span class="card-thumb-placeholder">{{ post.title|slice(0,1)|upper }}</span>
    {% endif %}
  </a>

  <div class="card-body">
    <div class="card-meta">
      <span class="avatar" aria-hidden="true">{{ (post.author|default('A'))|slice(0,1)|upper }}</span>
      <div class="card-meta-text">
        <span>{{ post.author|default('Admin') }}</span>
        <span class="card-meta-sub">
          {% if post.date %}<time>{{ post.date|date('M j') }}</time>{% endif %}
          {% if post.reading_time %} · {{ post.reading_time }} min read{% endif %}
        </span>
      </div>
    </div>

    <h3 class="card-title">
      <a href="{{ post.url }}">{{ post.title }}</a>
    </h3>

    {% if post.excerpt %}<p class="card-excerpt">{{ post.excerpt }}</p>{% endif %}
  </div>
</article>
