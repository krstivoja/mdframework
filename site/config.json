{
    "site": {
        "name": "My Site Marko",
        "base": "/"
    },
    "taxonomies": {
        "categories": {
            "label": "Categories",
            "multiple": false,
            "post_types": [
                "blog",
                "pages",
                "tutorials"
            ],
            "fields": [
                {
                    "name": "image",
                    "type": "single",
                    "value": ""
                },
                {
                    "name": "description",
                    "type": "single",
                    "value": ""
                },
                {
                    "name": "terms",
                    "type": "array",
                    "widget": "select",
                    "items": [
                        "tech",
                        "design",
                        "tutorial"
                    ]
                }
            ]
        },
        "tags": {
            "label": "Tags",
            "multiple": true,
            "post_types": [
                "blog",
                "tutorials"
            ],
            "fields": [
                {
                    "name": "terms",
                    "type": "array",
                    "widget": "checkbox",
                    "items": [
                        "gsap",
                        "php",
                        "css"
                    ]
                }
            ]
        }
    },
    "active_theme": "editorial",
    "uploads": {
        "max_mb": 5,
        "max_width": 0,
        "max_height": 0
    }
}