# ──────────────────────────────────────────────────────────────────
# Dependencies — regenerated via `composer install` / `npm ci`
# ──────────────────────────────────────────────────────────────────
cms/vendor/
src/node_modules/

# ──────────────────────────────────────────────────────────────────
# Build artifacts — regenerated via `npm run build`
# ──────────────────────────────────────────────────────────────────
public/cms/dist/
src/dist/
**/.vite/
.vite-hot

# ──────────────────────────────────────────────────────────────────
# Runtime caches — auto-rebuilt on first request
# ──────────────────────────────────────────────────────────────────
site/cache/

# ──────────────────────────────────────────────────────────────────
# User content — populated at install time, never tracked
# Exception: ship a starter homepage so a fresh install isn't 404
# ──────────────────────────────────────────────────────────────────
site/content/*
!site/content/pages/
site/content/pages/*
!site/content/pages/index.md
!site/content/blog/
site/content/blog/*
!site/content/blog/_index.md
!site/content/blog/hello-world.md

site/uploads/*
!site/uploads/index.php

# ──────────────────────────────────────────────────────────────────
# Local config / secrets
# ──────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ──────────────────────────────────────────────────────────────────
# Tool caches & local-only output
# ──────────────────────────────────────────────────────────────────
.phpunit.result.cache
.php-cs-fixer.cache
phpstan-baseline.neon
coverage/
*.log

# ──────────────────────────────────────────────────────────────────
# Editor / IDE
# ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ──────────────────────────────────────────────────────────────────
# OS metadata
# ──────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db

# ──────────────────────────────────────────────────────────────────
# Release artifacts
# ──────────────────────────────────────────────────────────────────
release/
*.zip
