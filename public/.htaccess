<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Admin routes → admin.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^admin(/.*)?$ admin.php [L,QSA]

# Frontend routes → index.php
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>
