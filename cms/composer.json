{
    "name": "marko/mdframework",
    "description": "Ultralight flat-file markdown framework",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "league/commonmark": "^2.4",
        "symfony/yaml": "^6.4",
        "enshrined/svg-sanitize": "^0.22.0"
    },
    "autoload": {
        "psr-4": {
            "MD\\": "lib/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "test": "phpunit -c ../phpunit.xml",
        "stan": "phpstan analyse --memory-limit=1G -c ../phpstan.neon",
        "check": [
            "@test",
            "@stan"
        ]
    }
}
