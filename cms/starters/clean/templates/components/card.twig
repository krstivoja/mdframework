{# Post card — receives:
     post     — page record from posts() / index
     featured — bool; renders larger hero variant when true #}
{% set cls = featured ? 'card card-featured' : 'card' %}
<article class="{{ cls }}">
  <a class="card-thumb" href="{{ post.url }}">
    {% if post.image %}
      <img src="{{ post.image }}" alt="{{ post.title }}">
    {% elseif post.cover %}
      <img src="{{ post.cover }}" alt="{{ post.title }}">
    {% else %}
      <span class="card-thumb-placeholder" aria-hidden="true">{{ post.title|slice(0,1)|upper }}</span>
    {% endif %}
  </a>

  <div class="card-body">
    {% if post.categories|default([])|length %}
      <div class="card-cats">
        {% for cat in post.categories|slice(0,2) %}
          <a class="tag" href="{{ slug_url(cat, 'categories') }}">{{ cat }}</a>
        {% endfor %}
      </div>
    {% endif %}

    <h3 class="card-title">
      <a href="{{ post.url }}">{{ post.title }}</a>
    </h3>

    {% if post.excerpt %}<p class="card-excerpt">{{ post.excerpt }}</p>{% endif %}

    <div class="card-meta">
      {% if post.author %}<span>{{ post.author }}</span><span class="dot">·</span>{% endif %}
      {% if post.date %}<time>{{ post.date|date('M j, Y') }}</time>{% endif %}
      {% if post.reading_time %}<span class="dot">·</span><span>{{ post.reading_time }} min read</span>{% endif %}
    </div>
  </div>
</article>
