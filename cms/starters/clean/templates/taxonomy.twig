{{ partial('header', { page_title: term ~ ' — ' ~ taxonomy|capitalize }) }}

<section class="archive">
  <h1>{{ taxonomy|capitalize }}: {{ term }}</h1>

  {% if posts is iterable and posts|length %}
    <div class="cards">
      {% for post in posts %}
        {{ partial('card', { post: post }) }}
      {% endfor %}
    </div>
  {% else %}
    <p>Nothing tagged <strong>{{ term }}</strong>.</p>
  {% endif %}

  {{ partial('pagination', {
    page: page|default(1),
    total_pages: total_pages|default(1),
    base_url: '/' ~ taxonomy ~ '/' ~ term_slug
  }) }}
</section>

{{ partial('footer') }}
